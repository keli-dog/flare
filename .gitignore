# Offline planner outputs (regenerate locally)
# =============================================================================
planner/planner_results/
planner/*failed.json
MMP_results_qwen/

# =============================================================================
# Eval outputs: keep text/small summaries for sharing; ignore heavy artifacts
# =============================================================================
results/pictures/
results/leaderboard/
results/analyze_recs/
results/completed_episodes*.p

# Allowed under results/ (will be committed if you git add them):
#   results/compare_*.txt          - GPT vs Qwen comparison reports
#   results/logs/*.txt             - per-episode eval logs
#   results/successes/*.p          - small pickle summaries
#   results/fails/*.p

